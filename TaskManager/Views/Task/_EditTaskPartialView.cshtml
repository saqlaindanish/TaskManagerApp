@model EditTaskViewModel

<div class="modal-header">
    <h5 class="modal-title">Edit Task</h5>
    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
</div>

<form class="modal-form" asp-action="EditTask" asp-controller="Task" method="post">
    <div class="modal-body">
        <input type="hidden" asp-for="TaskId" />
        <input type="hidden" asp-for="ReturnUrl" />
        <!-- Login form -->
        <div class="text-danger" asp-validation-summary="ModelOnly"></div>

        <div class="mb-3">
            <label asp-for="Title" class="form-label">Title</label>
            <input asp-for="Title" type="tel" class="form-control">
            <span class="text-danger" asp-validation-for="Title"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Description" class="form-label">Description</label>
            <input asp-for="Description" type="text" class="form-control">
            <span asp-validation-for="Description" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Priority" class="form-check-label">Priority</label>
            <select asp-for="Priority" asp-items="Html.GetEnumSelectList<TaskPriority>()" class="form-select">
                <option value="">-- Select Priority --</option>
            </select>
            <span asp-validation-for="Priority" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="Status" class="form-check-label">Status</label>
            <select asp-for="Status" asp-items="Html.GetEnumSelectList<Status>()" class="form-select">
                <option value="">-- Select Status --</option>s
            </select>
            <span asp-validation-for="Status" class="text-danger"></span>
        </div>
        <div class="mb-3">
            <label asp-for="DueDate" class="form-label"></label>
            <input type="datetime-local"  asp-for="DueDate"/>
            <span asp-validation-for="DueDate" class="text-danger"></span>
        </div>
    </div>

    <div class="modal-footer">
        <button type="submit" class="w-100 btn bg-gradient-primary text-white">Update</button>
    </div>
</form>

@section Scripts {

    <partial name="_ValidationScriptsPartial" />

}