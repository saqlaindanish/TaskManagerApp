@model IEnumerable<Notification>

@{
    ViewData["Title"] = "All Notifications";
}
<div class="container-fluid">
    <h1>All Notifications</h1>

    <hr />

     <div>
        @if(Model.Any() && Model.Count() > 0)
        {
            foreach(var notification in Model)
            {
                <a class="dropdown-item notification-item d-flex align-items-center p-2 @(notification.IsRead == false? "bg-gray-200":"")" href="/Notification/GetNotification?id=@(notification.Id)">
                    <div class="mr-3">
                        <div class="icon-circle bg-gradient-primary">
                            <i class="fas fa-tasks text-white"></i>
                        </div>
                    </div>
                    <div>
                        <div class="small text-gray-700 fw-bold">@notification.CreatedAt.ToString("MMMM dd yyyy (dddd) hh:mm tt")</div>
                        <span class="font-weight-bold">@notification.Message</span>
                    </div>
                </a>
            }
        }
        else
        {
            <p>Empty</p>
        }
    </div>
</div>
